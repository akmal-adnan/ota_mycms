# ============================================
# OTA Manager - Client Environment Variables
# ============================================
# Copy this file to .env and update values for your environment

# Development: Backend server URL (used by Vite dev server proxy)
# The dev server will proxy all /api requests to this target
# Default: http://localhost:3001 (backend runs locally)
# Example: http://localhost:3001, http://192.168.1.100:3001
API_TARGET=http://localhost:3001

# Optional: Production API URL (for built application)
# Set this if your production backend is at a different URL
# Example: https://api.example.com
# VITE_API_URL=https://api.example.com

# Optional: Debug mode for development
# Set to true to enable extra logging and React Query DevTools
# VITE_DEBUG=false